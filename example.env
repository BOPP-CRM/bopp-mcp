# BOPP API (required)
BOPP_API_BASE=https://odoo-dev.bopp.digital/api

# Public URL of this MCP server (required)
# Fly: https://<app-name>.fly.dev
MCP_SERVER_URL=

# Must match the hostname clients use (no https://)
# Fly: <app-name>.fly.dev
MCP_ALLOWED_HOSTS=

MCP_TRUST_PROXY=1

# Optional — Fly sets this in fly.toml via /data volume
# MCP_OAUTH_STORE=/data/.mcp-oauth-store.json

# OAuth session lifetime (seconds)
# MCP_ACCESS_TOKEN_TTL_SEC=86400        # 24 hours (default)
# MCP_REFRESH_TOKEN_TTL_SEC=31536000    # 365 days (default)

# Local dev only (stdio MCP) — not needed on Fly
# BOPP_API_KEY=
